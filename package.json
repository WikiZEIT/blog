  "type": "module",
  "bugs": {
    "url": "https://github.com/WikiZEIT/wikizeit/issues"
  },
  "homepage": "https://github.com/WikiZEIT/wikizeit#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@eslint/markdown": "^8.0.1",
    "better-sqlite3": "^12.10.0",
    "clean-css": "^5.3.3",
    "eleventy-plugin-svg-social-card": "^0.2.4",
    "eslint": "^10.2.1",
    "image-size": "^2.0.2",
