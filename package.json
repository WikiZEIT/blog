{
  "name": "wikizeit",
  "version": "0.1.0",
  "description": "Edukacyjny projekt o Wikipedii i etycznym SEO autorstwa [Jakuba T. Jankiewicza](https://jakub.jankiewicz.org/pl/). Odkryj mechanizmy największej encyklopedii świata i jej wpływu na twoją markę.",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/download-font.mjs",
    "prebuild": "node scripts/subset-font.mjs",
    "build": "eleventy",
    "dev": "eleventy --serve",
    "watch": "eleventy --watch",
    "lint": "eslint 'src/**/*.md'",
    "spell": "cspell --no-progress --dot \"src/**/*.md\" \"src/**/*.liquid\" \".eleventy.js\" \"scripts/*.mjs\" \"api/**/*.php\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WikiZEIT/wikizeit.git"
  },
  "keywords": [],
  "author": "Jakub T. Jankiewicz <jcubic@onet.pl> (https://jakub.jankiewicz.org/)",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/WikiZEIT/wikizeit/issues"
  },
  "homepage": "https://github.com/WikiZEIT/wikizeit#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@cspell/dict-pl_pl": "^3.0.6",
    "@eslint/markdown": "^8.0.1",
    "better-sqlite3": "^12.10.0",
    "clean-css": "^5.3.3",
    "cspell": "^10.0.1",
    "eleventy-plugin-svg-social-card": "^0.2.4",
    "eslint": "^10.2.1",
    "image-size": "^2.0.2",
    "subset-font": "^2.5.0",
    "terser": "^5.46.2"
  },
  "dependencies": {
    "eleventy-plugin-toc": "^1.1.5",
    "html-minifier-next": "^6.1.5",
    "markdown-it-anchor": "^9.2.0"
  }
}
