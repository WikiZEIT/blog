AddCharset UTF-8 .txt .md
AddType text/markdown .md

# HTTP Link headers (RFC 8288) for agent discovery
Header always set Link "</sitemap.xml>; rel=\"sitemap\", </llms.txt>; rel=\"describedby\"; type=\"text/plain\""

# Force HTTPS
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

# ==========================================================================
# Cache Control
# ==========================================================================

# Versioned assets (CSS/JS/fonts with ?v= hash) — cache for 1 year
<FilesMatch "\.(css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Images and favicons — cache for 30 days
<FilesMatch "\.(png|jpg|jpeg|webp|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# HTML and PHP — no cache (always fresh)
<FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

RewriteEngine On

RewriteRule ^graf-wiedzy/(.*) /tools/graf-wiedzy/$1 [R=301,L]

# Content negotiation: serve markdown when Accept: text/markdown
RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^$ /llms.txt [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^about/?$ /about.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^contact/?$ /contact.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^blog/?$ /blog.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteCond %{DOCUMENT_ROOT}/blog/$1.md -f
RewriteRule ^blog/([^/]+)/?$ /blog/$1.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteCond %{DOCUMENT_ROOT}/autor/$1.md -f
RewriteRule ^autor/([^/]+)/?$ /autor/$1.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^privacy/?$ /privacy.md [L,T=text/markdown]

RewriteCond %{HTTP:Accept} text/markdown
RewriteRule ^oferta/?$ /oferta/index.php?format=md [L,T=text/markdown]

RewriteRule ^oferta\.md$ /oferta/index.php?format=md [L]

# Protect sensitive files
RewriteRule ^oferta/allegro_tokens\.json$ /404.php [L]
RewriteRule ^oferta/\.git /404.php [L]
RewriteRule ^api/subscribers\.db$ /404.php [L]
RewriteRule ^api/templates/ /404.php [L]
RewriteRule ^api/lib/ /404.php [L]
RewriteRule ^api/composer\.(json|lock)$ /404.php [L]
RewriteRule ^vendor/ /404.php [L]
RewriteRule ^api/vendor/ /404.php [L]
RewriteRule ^api/logs/ /404.php [L]
RewriteRule ^api/mail/ /404.php [L]
RewriteRule ^tools/.*/config.json /404.php [L]

RewriteRule ^szkolenia/(.*)$ /oferta/$1 [R=301,L]

RewriteRule blog/nowa-masktka-wikipedii/ /blog/nowa-maskotka-wikipedii/ [R=301,L]

# Custom 404 – serve via PHP wrapper so the response status is 404, not 200
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /404.php [L]

