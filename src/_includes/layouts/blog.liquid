---
layout: layouts/base.liquid
---

<main class="blog-main">
  <div class="blog-header">
    {% if tag %}
      <h1 class="blog-title">Artykuły z tagiem: {{ tag }}</h1>
      <p class="blog-description">Wszystkie artykuły oznaczone tagiem "{{ tag }}".</p>
    {% else %}
      <h1 class="blog-title">{{ title | default: "Blog" }}</h1>
      <p class="blog-description">Artykuły o Wikipedii, etycznym SEO i otwartej wiedzy.</p>
    {% endif %}
  </div>

  {% if tag %}
    {% assign postsList = collections[tag] | reverse %}
  {% else %}
    {% assign postsList = posts %}
  {% endif %}

  {% if postsList.size > 0 %}
  <div class="posts-grid">
    {% for post in postsList %}
      {% unless post.data.tags contains "tool" %}
        {% include "partials/post-card.liquid", post: post %}
      {% endunless %}
    {% endfor %}
  </div>

  {% unless tag %}
    {% include "partials/pagination.liquid" %}
  {% endunless %}

  {% if tag %}
    {% assign hasTools = false %}
    {% for item in postsList %}
      {% if item.data.tags contains "tool" %}
        {% assign hasTools = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% if hasTools %}
    <h2 class="blog-title tag-tools-heading">Narzędzia</h2>
    <div class="tools-grid">
      {% for tool in postsList %}
        {% if tool.data.tags contains "tool" %}
          {% include "partials/tool-card.liquid", tool: tool %}
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  {% endif %}

  {% else %}
  <p class="text-slate-400">Brak artykułów do wyświetlenia.</p>
  {% endif %}
</main>
