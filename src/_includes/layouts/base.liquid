{% if page.outputPath contains ".php" %}<?php
ob_start();
require_once $_SERVER['DOCUMENT_ROOT'] . '/vendor/autoload.php';
?>{% endif %}
<!DOCTYPE html>
<html lang="{{ site.language }}">
  <head>
    {% include "head.liquid" %}
    <script>(function(){var t=localStorage.getItem('theme');if(t)document.documentElement.dataset.theme=t;})()</script>
    {% if schemaType == "home" %}
      {% include "partials/schema-home.liquid" %}
    {% elsif schemaType == "article" %}
      {% include "partials/schema-article.liquid" %}
    {% elsif schemaType == "tool" %}
      {% include "partials/schema-tool.liquid" %}
    {% endif %}
  </head>
  <body>
    {% include "partials/social-icons-sprite.liquid" -%}
    {% include "partials/nav.liquid" -%}

    {{- content -}}

    {% include "partials/footer.liquid" -%}
    {% include "partials/mobile-nav.liquid" -%}
    <script>
      document.querySelector('.menu-button').addEventListener('click', function() {
        document.querySelector('.nav-links').classList.toggle('open');
      });
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored) {
          var radio = document.getElementById('mode_' + stored);
          if (radio) radio.checked = true;
        }
        var radios = document.querySelectorAll('input[name="mode"]');
        radios.forEach(function(radio) {
          radio.addEventListener('change', function() {
            localStorage.setItem('theme', this.value);
            document.documentElement.dataset.theme = this.value;
          });
        });
      })();
    </script>
    <script defer src="https://umami.jcubic.pl/script.js" data-website-id="c716ef1c-b60b-455c-8279-58996a09a8a6"></script>
  </body>
</html>
{% if page.outputPath contains ".php" %}<?= ob_get_clean() ?>{% endif %}
