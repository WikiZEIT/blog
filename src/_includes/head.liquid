<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title | default: site.title }}</title>
<meta name="description" content="{{ description | default: site.longDescription }}">
{% if keywords %}<meta name="keywords" content="{{ keywords | join: ', ' }}">{% endif %}
<meta name="robots" content="{% if unlisted %}noindex, nofollow{% else %}index, follow{% endif %}" />
<!-- Favicon -->
<link rel="icon" type="image/png" href="{{ '/favicon/favicon-96x96.png' | url }}" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="{{ '/favicon/favicon.svg' | url }}" />
<link rel="shortcut icon" href="{{ '/favicon/favicon.ico' | url }}" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/favicon/apple-touch-icon.png' | url }}" />
<meta name="apple-mobile-web-app-title" content="WikiZEIT" />
<link rel="manifest" href="{{ '/favicon/site.webmanifest' | url }}" />
{% assign pageUrl = canonicalPath | default: page.url %}
<!-- Open Graph -->
<meta property="og:url" content="{{ site.url }}{{ pageUrl }}" />
<meta property="og:type" content="{% if layout == 'layouts/article.liquid' %}article{% else %}website{% endif %}" />
<meta property="og:locale" content="pl_PL" />
<meta property="og:site_name" content="{{ site.title }}" />
<meta property="og:title" content="{{ title | default: site.title }}" />
<meta property="og:description" content="{{ description | default: site.longDescription }}" />
<meta property="og:image" content="{{ site.baseUrl }}{{ ogImage | default: site.socialImage }}" />
{% if layout == 'layouts/article.liquid' %}
<meta property="article:published_time" content="{{ date | dateFormat: 'iso' }}" />
{% if modified %}<meta property="article:modified_time" content="{{ modified | dateFormat: 'iso' }}" />{% endif %}
<meta property="article:author" content="{{ site.url }}/autor/{{ author | default: site.author }}/" />
{% endif %}
<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="{{ site.url }}{{ pageUrl }}" />
<meta name="twitter:title" content="{{ title | default: site.title }}" />
<meta name="twitter:description" content="{{ description | default: site.longDescription }}" />
<meta name="twitter:image" content="{{ site.baseUrl }}{{ ogImage | default: site.socialImage }}" />
<meta name="twitter:creator" content="@{{ author | default: site.author }}" />
<!-- Canonical -->
<link rel="canonical" href="{{ site.url }}{{ pageUrl }}" />
{% if pagination.href.previous %}<link rel="prev" href="{{ pagination.href.previous | url }}" />
{% endif %}{% if pagination.href.next %}<link rel="next" href="{{ pagination.href.next | url }}" />
{% endif %}
<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="{{ site.title }} Blog" href="{{ site.url }}/feed.xml" />
{% assign mdHref = page.url | mdAlternate %}{% if mdHref %}<!-- Markdown alternate -->
<link rel="alternate" type="text/markdown" title="Markdown version" href="{{ mdHref }}" />{% endif %}
<!-- Fonts & CSS -->
{% assign cssHash = "/css/style.css" | contentHash %}{% assign iconHash = "/fonts/material-symbols-outlined.woff2" | contentHash %}{% assign interLatinExtHash = "/fonts/inter-latin-ext.woff2" | contentHash %}{% assign interLatinHash = "/fonts/inter-latin.woff2" | contentHash %}<link rel="preload" href="{{ '/fonts/inter-latin-ext.woff2' | url }}?v={{ interLatinExtHash }}" as="font" type="font/woff2" crossorigin />
<style>
@font-face{font-family:'Material Symbols Outlined';font-style:normal;font-display:swap;src:url('{{ "/fonts/material-symbols-outlined.woff2" | url }}?v={{ iconHash }}') format('woff2')}
@font-face{font-family:'Inter';font-style:normal;font-weight:100 900;font-display:swap;src:url('{{ "/fonts/inter-latin-ext.woff2" | url }}?v={{ interLatinExtHash }}') format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
@font-face{font-family:'Inter';font-style:normal;font-weight:100 900;font-display:swap;src:url('{{ "/fonts/inter-latin.woff2" | url }}?v={{ interLatinHash }}') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
</style>
<link rel="stylesheet" href="{{ '/css/style.css' | url }}?v={{ cssHash }}" />
{%- if schemaType == "article" and content contains 'class="language-' -%}
{% assign prismHash = "/css/prism-tomorrow.css" | contentHash %}<link rel="stylesheet" href="{{ '/css/prism-tomorrow.css' | url }}?v={{ prismHash }}" />
{%- endif -%}
<!-- Icon loading (progressive enhancement) -->
<script>
(function() {
    document.documentElement.classList.add('icons-hidden');
    function icons_ready() {
        document.documentElement.classList.remove('icons-hidden');
    }
    if (document.fonts && document.fonts.ready) {
        var font = '24px "Material Symbols Outlined"';
        document.fonts.load(font).then(icons_ready);
    } else {
        icons_ready();
    }
})();
</script>
