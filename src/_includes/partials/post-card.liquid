<a class="post-card" href="{{ post.url | url }}">
  {% if post.data.featuredImage %}
  <div class="post-card-image">
    <img src="{{ post.data.featuredImage | url }}" alt="{{ post.data.title }}" width="800" height="450" />
  </div>
  {% endif %}
  <div class="post-card-body">
    {% if post.data.tags %}
    <div class="post-card-tags">
      {% for tag in post.data.tags %}
        {% unless tag == "post" %}
        <span class="tag-badge">{{ tag }}</span>
        {% endunless %}
      {% endfor %}
    </div>
    {% endif %}
    {% assign heading_tag = card_heading | default: "h3" %}
    <{{ heading_tag }} class="post-card-title">{{ post.data.title }}</{{ heading_tag }}>
    <p class="post-card-excerpt">
      {% if post.data.description %}
        {{ post.data.description }}
      {% else %}
        {{ post.content | excerpt: 150 }}
      {% endif %}
    </p>
    <div class="post-card-meta">
      <span class="post-card-meta-item">
        <span class="material-symbols-outlined">calendar_today</span>
        {{ post.date | dateFormat }}
      </span>
      <span class="post-card-meta-item">
        <span class="material-symbols-outlined">schedule</span>
        {{ post.content | readingTime }}
      </span>
    </div>
  </div>
</a>
