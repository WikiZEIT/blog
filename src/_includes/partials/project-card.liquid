<a class="tool-card" href="{{ project.url | url }}">
  <span class="tool-icon material-symbols-outlined">{{ project.data.icon | default: "build" }}</span>
  <div class="tool-card-body">
    {% if project.data.tags %}
    <div class="post-card-tags">
      {% for tag in project.data.tags %}
      <span class="tag-badge">{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}
    <h3 class="tool-card-title">{{ project.data.title }}</h3>
    <p class="tool-card-desc">{{ project.data.description }}</p>
    <span class="tool-card-link">
      Zobacz projekt
      <span class="material-symbols-outlined">arrow_forward</span>
    </span>
  </div>
</a>
