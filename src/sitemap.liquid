---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- for page in collections.all %}
  {%- unless page.data.eleventyExcludeFromCollections or page.data.unlisted %}
  <url>
    <loc>{{ site.url }}{% if page.data.canonicalPath %}{{ page.data.canonicalPath }}{% else %}{{ page.url }}{% endif %}</loc>
    {%- assign pageDate = page.data.modified | default: page.date -%}
    <lastmod>{{ site.lastmod | newerDate: pageDate | dateFormat: "iso" }}</lastmod>
  </url>
  {%- endunless %}
  {%- endfor %}
  {%- for page in site.external %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.lastmod }}</lastmod>
  </url>
  {%- endfor %}
</urlset>
