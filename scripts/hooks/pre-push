#!/bin/bash
# Git pre-push hook — uruchamia watch-actions.sh w tle po każdym push.
# Zainstaluj: scripts/install-hooks.sh

ROOT_DIR="$(git rev-parse --show-toplevel)"
WATCHER="$ROOT_DIR/scripts/watch-actions.sh"

if [ ! -x "$WATCHER" ]; then
    echo "[pre-push] Brak wykonywalnego $WATCHER — pomijam watcher." >&2
    exit 0
fi

# Uruchom watcher w tle, odłączony od terminala
nohup "$WATCHER" > /dev/null 2>&1 &
disown

echo "[pre-push] Actions watcher uruchomiony w tle (PID $!)" >&2
exit 0
